#!/usr/bin/env node
/**
 * forge-gpu-check — Diagnostic tool to verify GPU is actually usable
 *
 * Usage:
 *   node bin/forge-gpu-check [--scene <scene.html>] [--verbose]
 *
 * What it checks:
 *   1. NVIDIA driver is installed (nvidia-smi works)
 *   2. GPU name + driver version + CUDA version
 *   3. ffmpeg has h264_nvenc encoder
 *   4. ffmpeg has hwupload_cuda + scale_npp filters (for full GPU pipeline)
 *   5. Chrome can launch with the project's GPU flags
 *   6. chrome://gpu reports Hardware accelerated (NOT SwiftShader)
 *   7. WebGL UNMASKED_RENDERER string (decisive SwiftShader check)
 *   8. (Optional) Renders 3 sample frames and measures GPU util via nvidia-smi
 *
 * Exit code:
 *   0 = GPU fully working
 *   1 = GPU detected but some check failed (see output for fix)
 *   2 = No NVIDIA GPU detected
 *
 * Example output (passing):
 *   ✓ NVIDIA driver: 525.85.12 (CUDA 12.0)
 *   ✓ GPU: Tesla T4
 *   ✓ ffmpeg h264_nvenc: available
 *   ✓ ffmpeg hwupload_cuda: available
 *   ✓ ffmpeg scale_npp: available
 *   ✓ Chrome launches with GPU flags
 *   ✓ chrome://gpu: Hardware accelerated
 *   ✓ WebGL renderer: ANGLE (NVIDIA Corporation, Tesla T4/PCIe/SSE2, ...)
 *   ✓ Sample render: GPU utilization 22% avg during 3-frame capture
 *
 *   All checks passed. GPU is fully utilized.
 */

const path = require('path');
const fs = require('fs');
const { Logger } = require('../src/core/Logger');
const { exec } = require('../src/utils/exec');
const env = require('../src/utils/environment');
const { verifyGpu, probeWebGLRenderer } = require('../src/utils/GpuVerifier');

function parseArgs(argv) {
  const opts = { scene: null, verbose: false, logLevel: 'info' };
  for (let i = 2; i < argv.length; i++) {
    const a = argv[i];
    const next = () => argv[++i];
    switch (a) {
      case '--scene': opts.scene = next(); break;
      case '--verbose': case '-v': opts.verbose = true; opts.logLevel = 'debug'; break;
      case '-h': case '--help':
        console.log(fs.readFileSync(__filename, 'utf8')
          .split('\n').filter(l => l.startsWith(' *')).map(l => l.slice(3)).join('\n'));
        process.exit(0);
    }
  }
  return opts;
}

const results = [];
function check(name, status, detail = '', fix = '') {
  const icon = status === 'pass' ? '✓' : status === 'fail' ? '✗' : '⚠';
  const line = `${icon} ${name}: ${detail}`;
  console.log(line);
  if (status === 'fail' && fix) console.log(`    Fix: ${fix}`);
  results.push({ name, status, detail, fix });
}

async function main() {
  const opts = parseArgs(process.argv);
  const logger = new Logger({ level: opts.logLevel, name: 'gpu-check' });
  const envInfo = env.detect();

  console.log('=== Digital Forge — GPU Diagnostic ===\n');
  console.log(`Environment: ${envInfo.platform} / Colab=${envInfo.isColab} / Docker=${envInfo.isDocker}`);
  console.log(`CPU cores: ${envInfo.cpus}`);
  console.log(`NVIDIA detected by env: ${envInfo.hasNvidia}`);
  console.log(`VAAPI device: ${envInfo.hasVaapi ? 'present' : 'absent'}\n`);

  // === 1. nvidia-smi ===
  let gpuName = null, driverVersion = null, cudaVersion = null;
  try {
    const { stdout } = await exec(['nvidia-smi',
      '--query-gpu=name,driver_version',
      '--format=csv,noheader']);
    const parts = stdout.trim().split(',').map(s => s.trim());
    gpuName = parts[0];
    driverVersion = parts[1];
    check('NVIDIA driver', 'pass', `${driverVersion} (${gpuName})`);
  } catch (e) {
    check('NVIDIA driver', 'fail', 'nvidia-smi not available',
      'Switch Colab to GPU runtime: Runtime → Change runtime type → T4 GPU. Then re-run setup-colab.sh.');
    console.log('\nCannot continue GPU diagnostic without an NVIDIA GPU.');
    process.exit(2);
  }

  // CUDA version (from nvidia-smi header)
  try {
    const { stdout } = await exec(['nvidia-smi'], { rejectOnNonZero: false });
    const m = stdout.match(/CUDA Version:\s*([\d.]+)/);
    if (m) cudaVersion = m[1];
  } catch { /* ignore */ }

  // === 2. ffmpeg encoders ===
  let ffmpegEncoders = '';
  try {
    const r = await exec(['ffmpeg', '-hide_banner', '-encoders']);
    ffmpegEncoders = r.stdout;
  } catch (e) {
    check('ffmpeg', 'fail', 'ffmpeg not installed', 'apt install ffmpeg');
    process.exit(1);
  }

  const hasNvenc = ffmpegEncoders.includes('h264_nvenc');
  check('ffmpeg h264_nvenc', hasNvenc ? 'pass' : 'fail',
    hasNvenc ? 'available' : 'NOT available',
    hasNvenc ? '' : 'Install ffmpeg built with NVENC: apt install ffmpeg');

  // === 3. ffmpeg filters (for hwupload pipeline) ===
  let ffmpegFilters = '';
  try {
    const r = await exec(['ffmpeg', '-hide_banner', '-filters']);
    ffmpegFilters = r.stdout;
  } catch { /* ignore */ }

  const hasHwupload = ffmpegFilters.includes('hwupload_cuda');
  const hasScaleNpp = ffmpegFilters.includes('scale_npp');
  check('ffmpeg hwupload_cuda', hasHwupload ? 'pass' : 'warn',
    hasHwupload ? 'available' : 'NOT available',
    hasHwupload ? '' : 'Install ffmpeg with CUDA support for full GPU pipeline (optional but faster)');
  check('ffmpeg scale_npp', hasScaleNpp ? 'pass' : 'warn',
    hasScaleNpp ? 'available' : 'NOT available');

  // === 4. Vulkan ICD (for Chrome GPU rasterization) ===
  const vulkanIcdExists = fs.existsSync('/usr/share/vulkan/icd.d')
                        && fs.readdirSync('/usr/share/vulkan/icd.d').some(f => f.includes('nvidia'));
  check('Vulkan ICD (nvidia)', vulkanIcdExists ? 'pass' : 'warn',
    vulkanIcdExists ? 'present' : 'NOT present',
    vulkanIcdExists ? '' : 'Install: apt install -y libnvidia-gl-525 libvulkan1 vulkan-tools');

  // === 5. EGL ICD (alternative path) ===
  const eglIcdExists = fs.existsSync('/usr/share/glvnd/egl_vendor.d')
                    && fs.readdirSync('/usr/share/glvnd/egl_vendor.d').some(f => f.includes('nvidia'));
  check('EGL ICD (nvidia)', eglIcdExists ? 'pass' : 'warn',
    eglIcdExists ? 'present' : 'NOT present');

  // === 6. Boot Chrome with GPU flags and check chrome://gpu ===
  console.log('\n--- Chrome GPU rasterization check ---');

  // ⚠️ CRITICAL: set FORGE_USE_GPU=1 before calling recommendedChromiumArgs()
  // so we actually get the GPU flags (not the CPU --disable-gpu --headless flags).
  // This was a bug in the original forge-gpu-check that produced false negatives.
  process.env.FORGE_USE_GPU = '1';

  const { chromium } = require('playwright');
  const args = env.recommendedChromiumArgs();
  console.log(`Chrome args: ${args.join(' ')}\n`);

  const executablePath = env.findChromium();
  if (!executablePath) {
    check('Chrome binary', 'fail', 'not found',
      'Run: npx playwright install chromium');
    process.exit(1);
  }
  console.log(`Chrome binary: ${executablePath}`);

  let browser, page;
  try {
    browser = await chromium.launch({ args, headless: true, executablePath });
    const ctx = await browser.newContext();
    page = await ctx.newPage();
    check('Chrome launches with GPU flags', 'pass', 'OK');
  } catch (e) {
    check('Chrome launches with GPU flags', 'fail', e.message,
      'Try: npx playwright install chromium');
    process.exit(1);
  }

  // chrome://gpu verification
  const gpuStatus = await verifyGpu(page, logger);
  if (gpuStatus.gpuActive) {
    check('chrome://gpu', 'pass', 'Hardware accelerated',
      `GL_RENDERER: ${gpuStatus.glRenderer}`);
  } else {
    check('chrome://gpu', 'fail',
      `SwiftShader fallback (CPU) — GL_RENDERER: ${gpuStatus.glRenderer}`,
      '',
      'Install NVIDIA Vulkan ICD: apt install -y libnvidia-gl-525 libvulkan1 vulkan-tools\n' +
      '  Then verify: vulkaninfo --summary | grep Tesla\n' +
      '  If still failing, try headed Chrome under xvfb-run as a fallback.');
  }

  // WebGL probe
  const webglRenderer = await probeWebGLRenderer(page);
  if (webglRenderer) {
    const looksLikeSwiftShader = /swiftshader|llvmpipe/i.test(webglRenderer);
    check('WebGL UNMASKED_RENDERER', looksLikeSwiftShader ? 'fail' : 'pass',
      webglRenderer,
      looksLikeSwiftShader ? 'This confirms Chrome is using CPU rasterization' : '');
  }

  await browser.close();

  // === 7. Optional: 3-frame sample render with GPU monitor ===
  if (opts.scene && fs.existsSync(opts.scene)) {
    console.log('\n--- Sample render test (3 frames) ---');
    const { GpuMonitor } = require('../src/utils/GpuMonitor');
    const { Config } = require('../src/config/Config');
    const { PlaywrightRenderer } = require('../src/renderers/PlaywrightRenderer');
    const { ensureDir } = require('../src/utils/fs');

    const tmpDir = path.join(require('os').tmpdir(), 'forge-gpu-check-' + Date.now());
    ensureDir(tmpDir);

    const config = new Config({
      htmlPath: path.resolve(opts.scene),
      framesDir: tmpDir,
      fps: 15,
      width: 1080, height: 1920,
      captureScale: 0.5,  // smaller = faster
      frameFormat: 'jpeg',
      useGpu: true,
      verifyGpu: true,   // ← enables Xvfb fallback if headless GPU fails
      resumeFromDisk: false
    });

    const mon = new GpuMonitor({ intervalMs: 200, logger });
    await mon.start();

    const renderer = new PlaywrightRenderer(config, logger);
    try {
      await renderer.init();
      for (let i = 0; i < 3; i++) {
        const ts = i / 15;
        const fp = path.join(tmpDir, `frame_${String(i).padStart(5, '0')}.jpg`);
        await renderer.renderFrame(ts, fp);
      }
      await renderer.close();
    } catch (e) {
      console.log(`Sample render failed: ${e.message}`);
    }

    const stats = await mon.stop();
    if (stats.active) {
      const cap = stats.byPhase.capture || {};
      const avg = cap.gpuUtilAvg || 0;
      check('Sample render GPU utilization',
        avg > 5 ? 'pass' : 'fail',
        `${avg}% avg over ${cap.count} samples (peak ${cap.gpuUtilPeak}%)`,
        avg < 5 ? 'GPU is idle during capture — Chrome is using SwiftShader' : '');
    }
    // Cleanup
    try { require('fs').rmSync(tmpDir, { recursive: true }); } catch { /* ignore */ }
  }

  // === Summary ===
  console.log('\n=== Summary ===');
  const passed = results.filter(r => r.status === 'pass').length;
  const failed = results.filter(r => r.status === 'fail').length;
  const warned = results.filter(r => r.status === 'warn').length;
  console.log(`${passed} passed, ${failed} failed, ${warned} warnings`);

  if (failed > 0) {
    console.log('\n✗ GPU is NOT being used. See failed checks above for fixes.');
    process.exit(1);
  } else if (warned > 0) {
    console.log('\n⚠ GPU is working but some optional optimizations are unavailable.');
    process.exit(0);
  } else {
    console.log('\n✓ All checks passed. GPU is fully utilized.');
    process.exit(0);
  }
}

main().catch(e => {
  console.error('Diagnostic failed:', e.message);
  console.error(e.stack);
  process.exit(1);
});
